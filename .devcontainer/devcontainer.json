{
  "name": "Ngoc Rong Server",
  "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/java:1": { "version": "17" }
  },
  "forwardPorts": [14445, 8080, 3306],
  "portsAttributes": {
    "14445": { "label": "Game Server", "onAutoForward": "notify" },
    "8080":  { "label": "HTTP Server", "onAutoForward": "notify" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack"]
    }
  }
}
