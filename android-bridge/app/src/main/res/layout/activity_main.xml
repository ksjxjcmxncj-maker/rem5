<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="top">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NRO WebSocket Bridge"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thay thế Termux — chạy bridge TCP→WebSocket trong nền"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WebSocket URL (Codespace/Replit):"
        android:textSize="14sp"
        android:textColor="#424242"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_ws_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="wss://xxx-8080.app.github.dev"
        android:inputType="textUri"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="#F5F5F5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ Start"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="■ Stop"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chưa chạy"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        android:padding="16dp"
        android:background="#F9FBE7" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\nSau khi Start:\n1. Mở game NRO\n2. Chọn máy chủ → Tùy chỉnh\n3. Nhập IP: 127.0.0.1  Port: 14445\n4. Chơi bình thường!"
        android:textSize="13sp"
        android:textColor="#424242"
        android:layout_marginTop="16dp" />

</LinearLayout>
